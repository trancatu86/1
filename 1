const getMountProperties = function(){
  const mountIds = $("#txt-avl-mount-ids").val().split(",");
  for (const [idx, mountId] of mountIds.entries())
    mountIds[idx] = Number(mountId.trim());

  const mountProperties = {}
  for (let idx=1; idx <= BUILDER_NUM_MOUNTS; idx++) {
    const container = $("#mount-param-sub-panel-" + idx);
    const cbxMountType = container.find(".cbx-mount-type");
    const mountType = cbxMountType.find(":selected").text();
    const dynStiffness = {};
    let isFixedInExcite = false;
    let matrixType = "none";
    if (mountType.toLowerCase() == "flexible"){
      matrixType = container.find(".mount-stiff-matrix-type-opts-container > input[type='radio']:checked").val().toLowerCase();
      const addedParamTableContainers = container.find("div.mount-param-div");
      const checkbox = container.find(".fix-checkbox-container > input[type='checkbox']");
      isFixedInExcite = checkbox.prop("checked");

      addedParamTableContainers.each( (_, paramTableDOMContainer) => {
        const paramTableContainer = $(paramTableDOMContainer);
        const matrixTerm = paramTableContainer.attr("matrix-term");
        const stiffnessLabel = matrixTerm.length == 3
                               ? matrixTerm.slice(0, 2) + "-" + matrixTerm.charAt(0) + matrixTerm.charAt(2)
                               : matrixTerm;

        const dataRows = paramTableContainer.find("tr.data-row");
        dynStiffness[stiffnessLabel] = [];
        dataRows.each( (key, item)=>{
          //each row
          const stiffnessAtFreq = []
          $(item).find("input").each( (idx, input) => {
            //each cell
            let value = $(input).val();
            let numVal = Number(value);
            if (idx == 0 && !value.trim() && isNaN(numVal) ) return false;
            if (isNaN(numVal)) value = 0.0;
            stiffnessAtFreq.push(numVal);
          });
          if (stiffnessAtFreq.length)
            dynStiffness[stiffnessLabel].push(stiffnessAtFreq);
        });
      })
    }
    
    mountProperties[mountIds[idx - 1]] = {
      "mountType": mountType,
      "matrixType": matrixType,
      "fixedInExcite": isFixedInExcite,
      "dynStiffness": dynStiffness
    }
  }
  console.log(mountProperties)
  return mountProperties;
}


