  const tableClassName = stiffnessTerm.length == 3
    ? stiffnessTerm.slice(0,2) + stiffnessTerm.charAt(0) + stiffnessTerm.charAt(2)
    : stiffnessTerm.slice(0,2) + stiffnessTerm.slice(3);
  paramTableContainer.addClass( tableClassName.toLowerCase() + "-dyn-stiffness")
                     .addClass("mount-param-div")
