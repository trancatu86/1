const writeMountDynStiffnessInfo = function(avlNids, mountParams){
  const container = $("<div>");
  const NUM_TABLES_PER_ROW = 3;

  for (let nid of avlNids){
    const Magrams = mountParams[nid];
    const mountDiv = $('<div class="dbinfo-single-mount-param-container">')
    const collapsible = $("<button>");
    collapsible.addClass("collapsible");
    const label = $("<span>");
    label.text("Mount NID " + nid);
    collapsible.append(label);
    const fixedInExcite = (Magrams["mount_type"] != "rigid" && Magrams["fixed_in_excite"]) ? " (Fixed in EXCITE)": "";
    const outputClassName = Magrams["mount_type"] == "rigid" ? "dbinfo-rigid-mount-label" : "dbinfo-flex-mount-label";
    const matrixType = Magrams["mount_type"] != "rigid" ? "/" + Magrams["matrix_type"] : "";
    const output = $("<output>");
    output.attr("readonly", "")
          .addClass(outputClassName)
          .val(capitalizeFirstLetter(Magrams["mount_type"]) + matrixType + fixedInExcite);
    collapsible.append(output);
    collapsible.click(onMountInfoPanelExpansionBtnClicked);
    mountDiv.append(collapsible);
    const dynstiffContainer = $('<div class="dbinfo-dynstiff-container">');
    const mountAxes = ["TX", "TY", "TZ", "RX", "RY", "RZ"];
    if (Magrams["mount_type"] == "flexible"){
      let numAddedTables = 0;
      let rowContainer;
      for (let targetAxis of mountAxes){
        for (let sourceAxis of mountAxes){
          const datasetName = targetAxis + "-" + sourceAxis;
          const tableName = targetAxis.charAt(0) == sourceAxis.charAt(0)
                            ? targetAxis + sourceAxis.charAt(1)
                            : datasetName;
          if (!Magrams["dyn_stiffness"].hasOwnProperty(datasetName))
            continue;

          if (numAddedTables % NUM_TABLES_PER_ROW == 0){
            numAddedTables++;
            rowContainer = $('<div class="dbinfo-dynstiff-row-container">');
            dynstiffContainer.append(rowContainer);
          }

          const axisDynstiffContainer = $('<div class="dbinfo-axis-dynstiff-container">');
          const table = $("<table>");
          table.append("<caption>" + tableName + " Dynamic Stiffness</caption>");
          table.append("<tr><th>Freq</th><th>Real</th><th>Imag</th></tr>");
          const data = Magrams["dyn_stiffness"][datasetName];
          for (let idx=0; idx < data.length; idx++){
            const rowData = data[idx];
            table.append('<tr><td class="right-align">' + rowData[0] + '</td><td class="right-align">' + rowData[1] + '</td><td class="right-align">' + rowData[2] + '</td></tr>');
          }
          axisDynstiffContainer.append(table);
          rowContainer.append(axisDynstiffContainer);
        }
      }
    }
    mountDiv.append(collapsible);
    mountDiv.append(dynstiffContainer);
    container.append(mountDiv);
    dynstiffContainer.hide();
  }
  return container;
}


const EquationType = Object.freeze({
  FULL: 0,
  SINGLE_MOUNT: 1,
  TPA: 2
})




const writeBodyTargetEquationTerms = function(numMounts, eqType=EquationType.FULL){
  let latex = `\\attr{math-term-group-id=bodyTarget}{\\class{math-term-group}{\\left[\\begin{array}{${"c".repeat(numMounts)}}`;
  if (eqType == EquationType.FULL) {
    for (let col=1; col <= numMounts; col++){
      latex += `\\attr{math-term-id=bodyTargetH-${col}}{\\class{math-term}{\\mathbf{H}_{${col}r}^B}}` + (col == numMounts ? "" : "&");
    }
  } else {
    for (let row=1; row <= numMounts; row++){
      for (let col=1; col <= numMounts; col++){
        if (col == row){
          latex += `\\attr{math-term-id=bodyTargetH-${col}}{\\class{math-term}{\\mathbf{H}_{${col}r}^B}}` + (col == numMounts ? "" : "&");
        } else {
          latex += "\\mathbf{0}" + (col == numMounts ? "" : "&");
        }
      }
      if (row != numMounts)
        latex += "\\\\";
    }
  }
  latex += "\\end{array}\\right]}}";
  return latex;
}

const writeBodyBodyEquationTerms = function(numMounts, eqType=EquationType.FULL){
  let latex = `\\attr{math-term-group-id=bodyMount}{\\class{math-term-group}{\\left[\\begin{array}{${"c".repeat(numMounts)}}`;
  for (let row=1; row <= numMounts; row++){
    for (let col=1; col <= numMounts; col++){
      if (eqType == EquationType.SINGLE_MOUNT && row != col){
        latex += "\\mathbf{0}" + (col == numMounts ? "" : "&");
      } else {
        latex += `\\attr{math-term-id=bodyMountH-${row}-${col}}{\\class{math-term}{\\mathbf{H}_{${row}-${col}}^B}}` + (col == numMounts ? "" : "&");
      }
    }
    if (row != numMounts)
      latex += "\\\\";
  }
  latex += "\\end{array}\\right]}}";
  return latex;
}

const writeEngineEngineEquationTerms = function(numMounts, eqType=EquationType.FULL){
  let latex = `\\attr{math-term-group-id=enMount}{\\class{math-term-group}{\\left[\\begin{array}{${"c".repeat(numMounts)}}`;
  for (let row=1; row <= numMounts; row++){
    for (let col=1; col <= numMounts; col++){
      if (eqType == EquationType.SINGLE_MOUNT && row != col){
        latex += "\\mathbf{0}" + (col == numMounts ? "" : "&");
      } else {
        latex += `\\attr{math-term-id=enMountH-${row}-${col}}{\\class{math-term}{\\mathbf{H}_{${row}-${col}}^E}}` + (col == numMounts ? "" : "&");
      }
    }
    if (row != numMounts)
      latex += "\\\\";
  }
  latex += "\\end{array}\\right]}}";
  return latex;
}

const writeMountStiffnessEquationTerms = function(numMounts, flexMountIdxs){
  const setFlexMountIdxs = new Set(flexMountIdxs);
  let latex = `\\omega^2\\attr{math-term-group-id=mountK}{\\class{math-term-group}{\\left[\\begin{array}{${"c".repeat(numMounts)}}`;
  for (let row=1; row <= numMounts; row++){
    for (let col=1; col <= numMounts; col++){
      if (row != col){
        latex += "\\mathbf{0}" + (col == numMounts ? "" : "&");
        continue;
      }
      if (!setFlexMountIdxs.has(row - 1)) {
        latex += "\\mathbf{0}" + (col == numMounts ? "" : "&");
        continue;
      }
      latex += `\\attr{math-term-id=mountK-${row}}{\\class{math-term}{\\mathbf{K}_{${row}}^{-1}}}` + (col == numMounts ? "" : "&");
    }
    if (row != numMounts)
      latex += "\\\\";
  }
  latex += "\\end{array}\\right]}}";
  return latex;
}

const writeExciteAccelEquationTerms = function(numMounts){
  let latex = `\\attr{math-term-group-id=AVLAcc}{\\class{math-term-group}{\\left[\\begin{array}{c}`;
  for (let row=1; row <= numMounts; row++){
    latex += `\\attr{math-term-id=AVLAcc-${row}}{\\class{math-term}{\\mathbf{A}_${row}^E}}`;
    if (row != numMounts)
      latex += "\\\\";
  }
  latex += "\\end{array}\\right]}}";
  return latex;
}

const writeResponseAccelEquationTerms = function(numMounts, eqType=EquationType.FULL){
  let latex = `\\left[\\begin{array}{c}`;
  if (eqType == EquationType.FULL)
    return latex + "\\mathbf{A}_r^B\\end{array}\\right]";

  for (let row=1; row <= numMounts; row++){
    latex += `\\mathbf{A}_{r/m${row}}^B`;
    if (row != numMounts)
      latex += "\\\\";
  }
  if (eqType == EquationType.SINGLE_MOUNT)
    return latex + "\\end{array}\\right]_{\\text{single-mount}}";
  return latex + "\\end{array}\\right]_{\\text{TPA}}";
}

const writeSynthesisEquationByEqType = function(eqType=EquationType.FULL){
  let latex = writeResponseAccelEquationTerms(NUM_MOUNTS, eqType);
  latex += "=" + writeBodyTargetEquationTerms(NUM_MOUNTS, eqType) 
            + "\\left(" 
            + writeBodyBodyEquationTerms(NUM_MOUNTS, eqType)
            + "-"
            + writeMountStiffnessEquationTerms(NUM_MOUNTS, FLEX_MOUNT_IDXS)
            + "+"
            + writeEngineEngineEquationTerms(NUM_MOUNTS, eqType)
            + "\\right)^{-1}"
            + writeExciteAccelEquationTerms(NUM_MOUNTS);
  return "\\begin{equation}" + latex + "\\end{equation}";
}

const writeSynthesisEquations = function(){
  const fullEq = writeSynthesisEquationByEqType(EquationType.FULL);
  const singleMountEq = writeSynthesisEquationByEqType(EquationType.SINGLE_MOUNT);
  const tpaEq = writeSynthesisEquationByEqType(EquationType.TPA);
  $("#equation-full").text(fullEq);
  $("#equation-single-mount").text(singleMountEq);
  $("#equation-transfer-path").text(tpaEq);
  if (MathJax.Hub) {
    MathJax.Hub.Config({TeX:{MAXBUFFER: 25600}});
    MathJax.Hub.Queue(["Typeset", MathJax.Hub, $("#equation-full")[0]]);
    MathJax.Hub.Queue(["Typeset", MathJax.Hub, $("#equation-single-mount")[0]]);
    MathJax.Hub.Queue(["Typeset", MathJax.Hub, $("#equation-transfer-path")[0]]);
  }
}


  
