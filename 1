const updateParamTableLayout = function(mountParamContainer){
  const addedMountParamTables = mountParamContainer.find("div.mount-param-div");
  const mountParamRows = mountParamContainer.find("div.single-mount-param-row");

  const NUM_TABLES_PER_ROW = 3;
  let currentWorkingMountParamRow;
  for (let idx = 0; idx < addedMountParamTables.length; idx++){
    if (idx % NUM_TABLES_PER_ROW == 0){
      currentWorkingMountParamRow = $('<div class="single-mount-param-row">');
      mountParamContainer.append(currentWorkingMountParamRow);
    }
    currentWorkingMountParamRow.append(addedMountParamTables.eq(idx));
  }
  if (mountParamRows.length)
    mountParamRows.remove();

}


const onRemoveParamTableClicked = function(e){
  const self = $(e.currentTarget);
  const paramTableDiv = self.parents(":eq(1)");
  const paramTableRowDiv = paramTableDiv.parent();
  const mountParamContainer = paramTableRowDiv.parent();
  const matrixTermSelector = mountParamContainer.prev().find("select");
  let needUpdateLayout = false;
  let isOnlyChildOfLastRow = false;

  if (!paramTableRowDiv.is(":last-child"))
    needUpdateLayout = true;
  else if (paramTableDiv.is(":last-child") && paramTableDiv.is(":first-child"))
    isOnlyChildOfLastRow = true;
    
  paramTableDiv.remove();
  if (isOnlyChildOfLastRow)
    paramTableRowDiv.remove();

  updateStiffnessMatrixTermSelector(matrixTermSelector);
  if (needUpdateLayout){
    updateParamTableLayout(mountParamContainer);
  }
}


