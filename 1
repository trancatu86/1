const onKeydownAllowPositiveFloatNumber = function(e) {
  if (e.keyCode == 109 || e.keyCode == 189){
    e.preventDefault();
  }
  onKeydownAllowFloatNumber(e);
}


const onKeydownAllowPositiveIntNumber = function(e) {
  if (e.keyCode == 109 || e.keyCode == 189){
    e.preventDefault();
  }
  onKeydownAllowIntNumber(e);
}


const onKeydownAllowFloatNumber = function(e){
  // Allow: backspace, delete, tab, escape, enter, +, -, and .
  if ($.inArray(e.keyCode, [46, 8, 9, 27, 13, 190, 110, 189, 109, 187, 107]) !== -1 ||
    // Allow: Ctrl+A
    (e.keyCode == 65 && e.ctrlKey === true) || 
    // Allow: home, end, left, right
    (e.keyCode >= 35 && e.keyCode <= 39)) {
    // let it happen, don't do anything
    return;
  }
  // Ensure that it is a number and stop the keypress
  if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
    e.preventDefault();
  }
}


const onKeydownAllowIntNumber = function(e){
  if (e.keyCode == 190 || e.keyCode == 110) {
    e.preventDefault();
  }
  onKeydownAllowFloatNumber(e);
}


const onParamPhaseCellTabKeydowned = function(e){
  const self = e.currentTarget;
  if (e.keyCode == 9 && !e.shiftKey) {
    // create new row
    const currentRow = $(self).parents(":eq(1)");
    if (currentRow.is(":last-child")) {
      e.preventDefault();
      const paramRow = createUserInputParamRows();
      const firstCell = paramRow.find("tr > td:first-child > input");
      currentRow.after(paramRow.children());
      firstCell.focus();
    }
  }
}


const createUserInputParamRows = function(numRows=1) {
  const container = $("<div>");
  for (let row = 0; row < numRows; row++) {
    const paramRow = $('<tr class="data-row">');
    for (let col=0; col < 3; col++)
      paramRow.append('<td><input type="text"></td>');
    
    cellInsertAfter = $("<td>");
    const btnInsertAfter = $("<span>");
    btnInsertAfter.addClass("glyphicon glyphicon-chevron-down");
    cellInsertAfter.append(btnInsertAfter);
    
    const btnRemoveRow = $("<span>");
    btnRemoveRow.addClass("glyphicon glyphicon-trash");
    const cellRemoveRow = $("<td>");
    cellRemoveRow.append(btnRemoveRow);
    
    paramRow.append(cellInsertAfter);
    paramRow.append(cellRemoveRow);
    
    btnRemoveRow.click(onParamRowTrashBtnClicked);
    btnInsertAfter.click(onParamRowInsertBtnClicked);
    container.append(paramRow);
  }
  
  const phaseInputs = container.find("tr > td:nth-child(3) > input");
  phaseInputs.on("keydown", onParamPhaseCellTabKeydowned);
  
  container.find("tr > td:first-child > input").on("keydown", onKeydownAllowPositiveFloatNumber);
  
  container.find("tr > td:not(:first-child) > input").on("keydown", onKeydownAllowFloatNumber);
  
  const freqInputs = container.find("tr > td:first-child > input");
  freqInputs.on("focus", onParamFreqCellFocused);
  
  return container;
}


