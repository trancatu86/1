const simplifyAString_MountAcce = function(str, word, number) {
  const items = str.split("_");
  const values = [];

  // Lấy các giá trị của các phần tử bắt đầu bằng 'A' và có số từ 1 đến 5
  for (let i = 1; i <= number; i++) {
    const key = word + `${i}`;
    const item = items.find(el => el.startsWith(key + ":"));
    if (!item) {
      // Nếu không tìm thấy phần tử nào, trả về chuỗi gốc
      return str;
    }
    const val = item.split(":")[1];
    values.push(val);
  }

  // Kiểm tra tất cả giá trị có giống nhau không
  const firstVal = values[0];
  const allEqual = values.every(v => v === firstVal);

  if (allEqual) {
    return word + firstVal;
  } else {
    return str; // Trả về chuỗi gốc nếu không thỏa điều kiện
  }
};

