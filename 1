const getUserOptions_blockedforce = function(){

  let opts = {
    "no_cross": document.querySelector("#single-mount").checked,
    "compute_contrib": document.querySelector("#transfer-path").checked,
  };
  
  let r1 = document.getElementById("result_Mag").checked ? 1 : 0;
  console.log("Value r1 =", r1);
  let r2 = document.getElementById("result_dB").checked ? 1 : 0;
  console.log("Value r2 =", r2);  
  let r3 = document.getElementById("result_dBA").checked ? 1 : 0;
  console.log("Value r3 =", r3);  
  let r4 = document.getElementById("result_dBA_3rd-Octave").checked ? 1 : 0;
  console.log("Value r4 =", r4);   
  let df_2 = document.getElementById("txt-df_2").value
  console.log("txt-df_2", df_2); 
  let response_allnodeid = document.getElementById("BF_txt-response-id").value 
  let response_allAcousticNodeID = document.getElementById("BF_txt-response-id").value 
  let response_allBodyNodeID = document.getElementById("BF_txt-body-response-id").value 
   

  const selectElem = document.getElementById('cbx-microphone-id_2');
  const currently_microphone = selectElem.options[selectElem.selectedIndex].text;
  console.log("currently_microphone", currently_microphone);
  
  

  opts["response_allAcousticNodeID"] = response_allAcousticNodeID;
  opts["response_allBodyNodeID"] = response_allBodyNodeID;  

  opts["r1"] = r1;
  opts["r2"] = r2;  
  opts["r3"] = r3;  
  opts["r4"] = r4;    
 
  
  let bf_pres_reflevel = document.getElementById("bf_txt-ref-pres").value
  let bf_acce_reflevel = document.getElementById("bf_txt-ref-acce").value 
  
  opts["bf_pres_reflevel"] = bf_pres_reflevel;
  opts["bf_acce_reflevel"] = bf_acce_reflevel;  
  
  opts["df_2"] = df_2;
  opts["response_allnodeid"] = response_allnodeid;   
  opts["currently_microphone"] = currently_microphone;   
  
  

  
  let avlFactors = {};
  for (let colIdx = 1; colIdx <= NUM_MOUNTS; colIdx++){
    avlFactors["H-" + colIdx] = parseFloat( $("#AVLAcc-" + colIdx).val() ) / 100.0 + 1.0;
    if (isNaN(avlFactors["H-" + colIdx]))
      avlFactors["H-" + colIdx] = 1.0;
  }

  opts["avl_mount_factors"] = avlFactors;
  console.log("avl_mount_factors", avlFactors); 

  
  let engineMountFactors = {};
  for (let rowIdx = 1; rowIdx <= NUM_MOUNTS; rowIdx++){
    for (let colIdx = 1; colIdx <= NUM_MOUNTS; colIdx++){
      let label = "-" + rowIdx + "-" + colIdx;
      engineMountFactors["H" + label] = parseFloat( $("#enMountH" + label).val() ) / 100.0 + 1.0;
      if (isNaN(engineMountFactors["H" + label]))
        engineMountFactors["H" + label] = 1.0;
    }
  }
  opts["engine_mount_factors"] = engineMountFactors;
  console.log("engine_mount_factors", engineMountFactors); 
  
  
  let mountFactors = {};
  for (let rowIdx of FLEX_MOUNT_IDXS){
    for (let colIdx = 1; colIdx <= 3; colIdx++){
      let label = "-" + (rowIdx + 1) + "-" + colIdx;
      mountFactors["H" + label] = parseFloat( $("#mountK" + label).val() ) / 100.0 + 1.0;
      if (isNaN(mountFactors["H" + label]))
        mountFactors["H" + label] = 1.0;
    }
  }
  opts["mount_factors"] = mountFactors;
  console.log("mount_factors", mountFactors); 

  let bodyMountFactors = {};
  for (let rowIdx = 1; rowIdx <= NUM_MOUNTS; rowIdx++){
    for (let colIdx = 1; colIdx <= NUM_MOUNTS; colIdx++){
      let label = "-" + rowIdx + "-" + colIdx;
      bodyMountFactors["H" + label] = parseFloat( $("#bodyMountH" + label).val() ) / 100.0 + 1.0;
      if (isNaN(bodyMountFactors["H" + label]))
        bodyMountFactors["H" + label] = 1.0;
    }
  }
  opts["body_mount_factors"] = bodyMountFactors;
  console.log("body_mount_factors", bodyMountFactors); 
  
  
  let bodyTargetFactors = {};
  for (let colIdx = 1; colIdx <= NUM_MOUNTS; colIdx++){
    bodyTargetFactors["H-" + colIdx] = parseFloat( $("#bodyTargetH-" + colIdx).val() ) / 100.0 + 1.0;
    if (isNaN(bodyTargetFactors["H-" + colIdx]))
      bodyTargetFactors["H-" + colIdx] = 1.0;
  }
  opts["body_target_factors"] = bodyTargetFactors;
  console.log("body_target_factors", bodyTargetFactors); 

  
  opts["invisible_groups"] = getInvisibleGroups();
  opts["zoom_range"] = getCurrentZoomRange();
  opts["show_history"] = $("#show-history").prop("checked");
  opts["show_db"] = $("#show-db").prop("checked");
  opts["a_weight"] = $("#a-weight").prop("checked");
  opts["chart_height"] = $("#chart-height").val();
  opts["rpm"] = $("#cbx-rpm-selector").find(":selected").text();
  opts["response_id"] = $("#cbx-microphone-id").find(":selected").text();
  
  opts["target_resp_label"] = $("#cbx-response-label").find(":selected").text();


  
  opts["oct3rd"] = $("#oct3rd").prop("checked");
  opts["no_rot"] = $("#no-rot").prop("checked");
  opts["df"] = parseFloat($("#txt-df").val());

  return opts;
}

