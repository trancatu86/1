def create_sensitive_file(PreFilename, node_id, mount_number):
    import re
    folder_path = os.path.join(wrkdir, "Sensitive")
    csv_files = [f for f in os.listdir(folder_path) if f.endswith('.csv')]
    def extract_leading_number(filename):
        match = re.match(r'^(\d+)', filename)
        if match:
            return int(match.group(1))
        else:
            return float('inf')  # nếu không tìm thấy số, cho lên cuối
    csv_files_sorted = sorted(csv_files, key=extract_leading_number)

    dfs = []
    for file in csv_files_sorted:
        file_path = os.path.join(folder_path, file)
        df = pd.read_csv(file_path)
        # Xóa cột đầu tiên (theo vị trí)
        df = df.iloc[:, 1:]
        dfs.append(df)



    result = pd.concat(dfs, axis=1, ignore_index=False)


    merged_file = current_path + "\\Sensitive\\merged_"+ str(node_id) +".csv"	
    result.to_csv(merged_file, index=False)
    template_file = current_path + "\\templates\\Mount_sensitive_template.xlsm"
    sensitive_file = current_path + "\\Sensitive\\" + PreFilename +"_Sensitive_"+ str(node_id) +".xlsm"	
    df = pd.read_csv(merged_file)

    excel = win32.DispatchEx('Excel.Application')
    excel.Visible = False  # ẩn Excel khi chạy


    wb = excel.Workbooks.Open(os.path.abspath(template_file))
    ws = wb.Sheets("Data_TFS_Export")

    data = df.values.tolist()

    start_row = 2
    start_col = 2  # cột B

    def col_num_to_letter(n):
        string = ""
        while n > 0:
            n, remainder = divmod(n - 1, 26)
            string = chr(65 + remainder) + string
        return string

    end_row = start_row + len(data) - 1
    end_col = start_col + len(data[0]) - 1

    start_cell = f"{col_num_to_letter(start_col)}{start_row}"
    end_cell = f"{col_num_to_letter(end_col)}{end_row}"
    write_range = f"{start_cell}:{end_cell}"

    ws.Range(write_range).Value = data


    
    if mount_number == 3:    
        excel.Application.Run("mount_3")  
    if mount_number == 5:    
        excel.Application.Run("mount_5") 
        
    # Chạy macro RefreshPivotTable
    excel.Application.Run("RefreshPivotTable")
    
    wb.SaveAs(os.path.abspath(sensitive_file))
    wb.Close()
    os.remove(merged_file)
    for file_name in csv_files:
        file_path = os.path.join(folder_path, file_name)
        if os.path.isfile(file_path):
            os.remove(file_path)




            
