    # Lấy danh sách tên file/thư mục trong folder_path
    items = os.listdir(csv_file_path)
    # Tạo danh sách đường dẫn đầy đủ
    body_files_csv_converted = [os.path.join(csv_file_path, item) for item in items]
      
      
