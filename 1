const backup_csv = function(a, b){
  let execButton = $("#btn-backup-csv");
  let csv_name = a;
  let folder_path = b;  
  $.ajax({
    type: "POST",
    url: "/backup_csv",
    data: JSON.stringify({filename: csv_name, path: folder_path}),
    contentType: "application/json",
    dataType: "json",
    success: (response)=>{
      if (response["status"] == "nodata"){   
        execButton.text("No Data!");
        execButton.css("cssText", "background-color: #C75476");
      } else if (response["status"] == "ok"){   
        const link = document.createElement("a");
        link.href = "/download_csv/" + response["downloadToken"];
        link.dispatchEvent(new MouseEvent('click'));
      }
      setTimeout( ()=>{
        execButton.text("Backup Database");
        execButton.css("cssText", "background-color: LightSteelBlue");
      }, 1000);   
    }
  });
}
