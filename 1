const validateInputFieldRealTime = function(inputField, validateFn, preprocessorFn=null, ...args) {
  /*
    `inputField`: (jqueryObj) the input field to be validated
    `validateFn`: (callable) function to validate the input field
    `preprocessorFn`: (optional[callable]) preprocessing function applied on `inputField` which yields...
                      the first argument for `validateFn`.
                      if it is null, the first argument of `validateFn` will be the id of `inputField`.
    `...args`: (optional[any]) the other arguments of validateFn
  */
  let validateFnInput = inputField.attr("id");
  if (preprocessorFn !== null) {
    validateFnInput = preprocessorFn(inputField);
  }

  if ( !validateFn(validateFnInput, ...args) ) {
    inputField.css("border-color", "red");
    inputField.on("focus", (e) => {
      $(e.currentTarget).css({"border-color": "red",
                              "outline-color": "red"});
    }).on("blur", (e)=> {
      $(e.currentTarget).css({"border-color": "red",
                              "border-width": "1px"});
    });
    inputField.focus();
    return false;
  }
  inputField.on("focus", (e) => {
    $(e.currentTarget).css({"border-color": "",
                            "outline-color": ""});
  }).on("blur", (e)=> {
    $(e.currentTarget).css({"border-color": "",
                            "border-width": ""});
  });
  return true;
}


