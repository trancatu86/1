  global all_str
  print("Start updating data")   
  inputs = request.get_json()
#  all_str = inputs.get('all_str', '')  
#  print("update_graph_all_str")  
#  print(all_str)
  if inputs["no_cross"]:
    request_display_type = "no_cross"
  elif inputs["compute_contrib"]:
