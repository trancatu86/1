function simplifyKString(str, prefix, axes) {
  const items = str.split("_");
//  const axes = ['x', 'y', 'z'];
  const values = [];

  for (let i = 0; i < axes.length; i++) {
    const key = `${prefix}${axes[i]}`;
    const item = items.find(el => el.startsWith(key + ":"));
    if (!item) {
      // Nếu không tìm thấy phần tử nào, trả về chuỗi gốc
      return str;
    }
    const val = item.split(":")[1];
    values.push(val);
  }

  const firstVal = values[0];
  const allEqual = values.every(v => v === firstVal);

  if (allEqual) {
    return `${prefix}:${firstVal}`;
  } else {
    return str;
  }
}

function simplifyAllKStrings(str,prefixes,axes) {
//  const prefixes = ["K1", "K2", "K3", "K4", "K5"];
  const results = [];

  for (const prefix of prefixes) {
    const simplified = simplifyKString(str, prefix, axes);
    // Nếu kết quả khác chuỗi gốc, tức là đã rút gọn
    if (simplified !== str) {
      results.push(simplified);
    }
  }

  // Nếu không có gì rút gọn, trả về chuỗi gốc
  if (results.length === 0) return str;

  // Nối các kết quả rút gọn bằng dấu gạch dưới
  return results.join("_");
}

