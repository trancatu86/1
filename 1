const updateDB_BlockedForce = function(){

  BF_bodyFiles = $("#BF_body-mount-pch-selector").prop('files');
  console.log(BF_bodyFiles);
  BF_ReactionForceFiles = $("#BF_avl-mount-selector").prop('files');
  console.log(BF_ReactionForceFiles);  

  let k = document.getElementById("BF_BodySideFileType_punch").checked ? 1 : 2;
  console.log("Value k =", k);
  
  let h = document.getElementById("BF_ResultType_acoustic").checked ? 1 : 2;
  console.log("Value h =", h);

  
  let BF_fd = new FormData();
  BF_fd.append('BF_BodySideType',k)
  BF_fd.append('BF_ResultType',h)
  
  $.each(BF_bodyFiles, (idx, file)=>{
    BF_fd.append('BF_bodyFiles', file)
  })
  
  $.each(BF_ReactionForceFiles, (idx, file)=>{
    BF_fd.append('BF_ReactionForceFiles', file)
  })

  var selected = $("input[name='resultType']:checked").attr('id');

  if (selected === "BF_ResultType_acoustic") {
	BF_fd.append("BF_responseId", $("#BF_txt-response-id").val());
  } else if (selected === "BF_ResultType_structure") {
	BF_fd.append("BF_responseId", $("#BF_txt-body-response-id").val());
  }

  BF_fd.append("BF_body_responseId", $("#BF_txt-body-response-id").val());  

  BF_fd.append("BF_bodymountId", $("#BF_txt-body-mount-ids").val());  
  
  BF_fd.append("BF_loadAtFinish", $("#BF_load-created-db").prop("checked"));  
  
  $.ajax({
    type: "POST",
    url: "/update_db_BlockedForce",
    data: BF_fd,
    contentType: false,
    cache: false,
    processData: false,
    dataType: "json",
    success: (response)=>{
      if (!response["status"]){
        execButton.text("Error Occured!");
        execButton.css("cssText", "background-color: #C75476")
        setTimeout( ()=>{
          execButton.text("Build Database");
          execButton.css("cssText", "background-color: DodgerBlue");
        }, 1000);
        return;
      }
      const dbinfo = response["data"];
      console.log(dbinfo["response_id"]);  	  
      updateMicrophoneList_BlockedForce(dbinfo["response_id"]);	  
      update_graph_BlockedForce(true);

      setTimeout( ()=>{
        execButton.text("Caculate");
        execButton.css("cssText", "background-color: DodgerBlue");
      }, 1000);
    }
  });
}
  
