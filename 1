}


const readParamsFromCsv = function(csvText){
  const lines = csvText.split("\r\n");
  const paramData = [];
  for (let line of lines){
    let lineItems = line.split(",")
    if (lineItems.length != 3)
      continue;

    const paramLine = [];
    lineItems.forEach((item) => {
      paramLine.push(Number(item));
    });
    paramData.push(paramLine);
  }
  return paramData;
}


const onClearParamRowsBtnClicked = function(obj){
  const outerDiv = $(obj.currentTarget).parent();
  const table = outerDiv.prev("table");
  const [axisLabel] = table.find("caption").text().split(" ", 1);
  table.remove();
  // table.append(createUserInputParamRows().children());
  outerDiv.before(createSingleUserDefinedMountParamTable(axisLabel));
}

const onImportCsvParamBtnClicked = function(obj, btnInsertCsv){
  const outerDiv = $(obj.currentTarget).parent();
  const input = $("<input>");
  const currentTable = outerDiv.prev();
  const [axisLabel] = currentTable.find("caption").text().split(" ", 1);
  input.attr("type", "file");
  input.attr("accept", ".csv");
  input.on("change", (e) => {
    const [file] = input.prop("files");
    
    const reader = new FileReader();
    reader.readAsText(file, "utf-8");
    reader.onload = function(){
      paramList = readParamsFromCsv(reader.result);
      if (!paramList.length) return;
      const numRows = paramList.length;
      const table = createSingleUserDefinedMountParamTable(axisLabel, numRows, "___" + file.name );
      const rows = table.find(".data-row");
      rows.each( (rowIdx, row) => {
        const inputs = $(row).find("input");
        const rowParams = paramList[rowIdx]
        inputs.each( (colIdx, input) => {
          $(input).val(rowParams[colIdx]);
        });
      });
      
      currentTable.remove();
      outerDiv.before(table);
    };
  });
  input.click();
}


