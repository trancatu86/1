const isPositiveInt = function(val){
  let num = Number(val);
  return Number.isInteger(num) && num > 0;
}


const isPositiveFloat = function(val){
  let num = Number(val);
  return !isNaN(num) && num > 0;
}


const trimCharStart = function(text, char) {
  const trimStartRegEx = new RegExp("^" + char + "+");
  return text.replace(trimStartRegEx, "");
}

const trimCharEnd = function(text, char) {
  const trimEndRegEx = new RegExp(char + "+$");
  return text.replace(trimEndRegEx, "");
}

const trimChar = function(text, char){
  return trimCharEnd(trimCharStart(text, char), char);
}


const validateInputNids = function(inputFieldId, checkEnough=true){
  let input = $("#" + inputFieldId).val();
  if (!input.trim()) return false;
  let inputItems = trimChar(input, ",").split(",");
  if (checkEnough && inputItems.length != BUILDER_NUM_MOUNTS) return false;
  let test = true;
  inputItems.every( (item)=>{
    if ( !isPositiveInt(item) ){ test = false; return false; }
    return true;
  });
  return test;
}


const validateInputMountProperty = function(inputFieldId, allowNegative=false) {
  let val = $("#" + inputFieldId).val();
  if (!val.trim()) return false;
  if (!allowNegative && !isPositiveFloat(val)) return false;
  if (allowNegative && isNaN(Number(val)) ) return false;
  return true;
}


const validateInputMountPropertyFields = function(){
  for (let idx = 1; idx <= BUILDER_NUM_MOUNTS; idx++){
    if ( !validateInputMountProperty("txt-sls" + idx + "-c1") ) return false;
    
    if ( !validateInputMountProperty("txt-sls" + idx + "-c2") ) return false;
    
    if ( !validateInputMountProperty("txt-sls" + idx + "-d1", true) ) return false;
    
    for (let dirIdx=1; dirIdx <= 3; dirIdx++)
      if ( !validateInputMountProperty("txt-ftab" + idx + "-k" + dirIdx) ) return false;
  }
  return true;
}


const validateInputMountingAngle = function(dirLabel){
