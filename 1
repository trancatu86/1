const capitalizeFirstLetter = function(str){
  return str.charAt(0).toUpperCase() + str.slice(1);
}


class SliderGenerator{
  constructor(baseSliderId, baseSliderClass, baseSliderLabel){
    this.baseSliderId = baseSliderId;
    this.baseSliderClass = baseSliderClass;
    this.baseSliderLabel = baseSliderLabel;
    this._createSliderClasses = null;
    this._createSliderId = null;
    this._createSliderLabel = null;
    this._baseCheckboxId = "";
    this._baseCheckboxLabel = "";
    this._baseCheckboxClass = "";
    this._createCheckboxLabel = null;
    this._createCheckboxClasses = null;
    this._createCheckboxId = null;
  }
  
  setSliderIdCreator(sliderIdCreator){
    // sliderIdCreator is a callable that takes
    // base id, row index, and column index
    // and returns the id for the slider
    this._createSliderId = sliderIdCreator;
  }
  
  createSliderId(rowIdx, colIdx){
    return this._createSliderId(this.baseSliderId, rowIdx, colIdx);
  }
  
  setSliderClassCreator(sliderClassCreator){
    this._createSliderClasses = sliderClassCreator;
  }
  
  createSliderClasses(rowIdx, colIdx){
    return this._createSliderClasses(this.baseSliderClass, rowIdx, colIdx);
  }
  
  setSliderLabelCreator(sliderLabelCreator){
    this._createSliderLabel = sliderLabelCreator;
  }
  
  createSliderLabel(rowIdx, colIdx){
    return this._createSliderLabel(this.baseSliderLabel, rowIdx, colIdx);
  }
  
  setCheckboxIdCreator(checkboxIdCreator){
    this._createCheckboxId = checkboxIdCreator;
  }
  
  createCheckboxId(rowIdx){
    return this._createCheckboxId(this._baseCheckboxId, rowIdx);
  }
  
  setCheckboxClassCreator(checkboxClassCreator){
    this._createCheckboxClasses = checkboxClassCreator;
  }
  
  createCheckboxClasses(rowIdx){
    return this._createCheckboxClasses(this._baseCheckboxClass, rowIdx);
  }
  
  setCheckboxLabelCreator(checkboxLabelCreator){
    this._createCheckboxLabel = checkboxLabelCreator;
  }
  
  createCheckboxLabel(rowIdx){
    return this._createCheckboxLabel(this._baseCheckboxLabel, rowIdx);
  }
  
  setCheckboxBaseValues(baseId, baseClass, baseLabel){
    this._baseCheckboxId = baseId;
    this._baseCheckboxClass = baseClass;
    this._baseCheckboxLabel = baseLabel;
  }
  
  createSlider(sliderId, sliderClasses, sliderLabel, rowIdx, colIdx){
    const sliderContainer = $("<div>");
    sliderClasses.forEach((cls) => sliderContainer.addClass(cls));
    sliderContainer.addClass("row-" + rowIdx)
                   .addClass("tuning-col");
    const label = $("<label>");
    label.attr("for", sliderId);
    label.text(sliderLabel);
    const sliderValIndicator = $("<output>");
    sliderValIndicator.attr("id", "num" + capitalizeFirstLetter(sliderId));
    sliderValIndicator.text(0);
    label.append(sliderValIndicator);
    sliderContainer.append(label);
    const slider = $("<input>");
    slider.addClass("slider")
          .attr("id", sliderId)
          .attr("type", "range")
          .attr("min", -50)
          .attr("max", 50)
          .attr("value", 0)
          .attr("step", 5)
          .attr("list", "values");
    sliderContainer.append(slider);
    return sliderContainer;
  }

  createSliderRow(rowIdx, numSliders){
    // labelGenerator is a callable that takes
    // rowIdx and colIdx as its parameters and generate the label
    const sliderRowContainer = $("<div>");
    sliderRowContainer.addClass("tuning-row");
    for (let colIdx = 1; colIdx <= numSliders; colIdx++){
      const sliderId = this.createSliderId(rowIdx, colIdx);
      const sliderClasses = this.createSliderClasses(rowIdx, colIdx);
      const sliderLabel = this.createSliderLabel(rowIdx, colIdx);
      const slider = this.createSlider(sliderId, sliderClasses, sliderLabel, rowIdx, colIdx)
      sliderRowContainer.append(slider);
    }
    return sliderRowContainer;
  }
  
  createCheckboxRow(rowIdx){
    const pdiv = $("<div>");
    pdiv.addClass("tuning-row");
    const innerDiv = $("<div>");
    innerDiv.addClass("content-centered");
    this.createCheckboxClasses(rowIdx).forEach((cls) => innerDiv.addClass(cls));
    /*const label = $("<label>");
    label.addClass("always-hidden");
    label.attr("for", this.createCheckboxId(rowIdx));
    label.text(this.createCheckboxLabel(rowIdx));
    innerDiv.append(label);*/
    const checkbox = $("<input>");
    checkbox.attr("type", "checkbox")
            .attr("id", this.createCheckboxId(rowIdx));
    innerDiv.append(checkbox);
    pdiv.append(innerDiv);
    return pdiv;
  }
  
  createPanelSliders(numRows, numSlidersPerRow=numRows, linkRowSliders=false){
    const container = $("<div>");
    let rightDiv = container;
    if (linkRowSliders){
      container.append('<div class="left-col">Linked</div>');
      container.append('<div class="right-col always-hidden">Tuning</div>');
      const leftDiv = $("<div>");
      leftDiv.addClass("left-col");
      for (let rowIdx = 1; rowIdx <= numRows; rowIdx++) {
        leftDiv.append(this.createCheckboxRow(rowIdx));
      }
      container.append(leftDiv);
      rightDiv = $("<div>");
      rightDiv.addClass("right-col");
    }
    for (let rowIdx = 1; rowIdx <= numRows; rowIdx++){
      rightDiv.append(this.createSliderRow(rowIdx, numSlidersPerRow));
    }
    if (linkRowSliders)
      container.append(rightDiv);
    return container;
  }
}


