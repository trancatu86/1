const createMountStiffnessMatrixTermOptions = function(skipList=null, matrixType="symm"){
  const matrixTermsByMatrixType = {
    symm: {
      translationTerms: {
        label: "Translational Stiffness Terms",
        terms: ["TXX", "TYY", "TZZ", "TXY", "TXZ", "TYZ"]
      },
      rotationTerms: {
        label: "Rotational Stiffness Terms",
        terms: ["RXX", "RYY", "RZZ", "RXY", "RXZ", "RYZ"]
      },
      translationRotationTerms: {
        label: "Translation-Rotational Stiffness Terms",
        terms: ["TX-RX", "TX-RY", "TX-RZ", "TY-RX", "TY-RX", "TY-RY", "TY-RZ", "TZ-RX", "TZ-RY", "TZ-RZ"]
      }
    },
    unsymm: {
      translationTerms: {
        label: "Translational Stiffness Terms",
        terms: ["TXX", "TYY", "TZZ", "TXY", "TXZ", "TYZ", "TYX", "TZX", "TZY"]
      },
      rotationTerms: {
        label: "Rotational Stiffness Terms",
        terms: ["RXX", "RYY", "RZZ", "RXY", "RXZ", "RYZ", "RYX", "RZX", "RXY"]
      },
      translationRotationTerms: {
        label: "Translation-Rotational Stiffness Terms",
        terms: ["TX-RX", "TX-RY", "TX-RZ", "TY-RX", "TY-RX", "TY-RY", "TY-RZ", "TZ-RX", "TZ-RY", "TZ-RZ"]
      },
      rotationTranslationTerms: {
        label: "Rotation-Translational Stiffness Terms",
        terms: ["RX-TX", "RX-TY", "RX-TZ", "RY-TX", "RY-TX", "RY-TY", "RY-TZ", "RZ-TX", "RZ-RY", "RZ-TZ"]
      }
    }
  }

  const matrixTermGroupKeys = {
    symm: ["translationTerms", "rotationTerms", "translationRotationTerms"],
    unsymm: ["translationTerms", "rotationTerms", "translationRotationTerms", "rotationTranslationTerms"],
  }
  
  const container = $("<div>");
  const matrixTerms = matrixTermsByMatrixType[matrixType];

  if (skipList !== null)
    skipList = new Set(skipList);
  
  for (let termGroupKey of matrixTermGroupKeys[matrixType]) {
    const termGroup = $("<optgroup>");
    termGroup.attr("label", matrixTerms[termGroupKey].label);
    for (let term of matrixTerms[termGroupKey].terms) {
      if (skipList === null || skipList.has(term))
        continue;
      
      termGroup.append('<option value="' + term + '">' + term + "</option>");
    }
    container.append(termGroup)
  }
  return container;
}


